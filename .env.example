# Azure Bot Registration
BOT_ID=your_bot_app_id
BOT_PASSWORD=your_bot_app_password
BOT_TENANT_ID=your_tenant_id
BOT_TYPE=SingleTenant

# Toast MCP Server
MCP_SERVER_URL=http://localhost:3000/mcp
MCP_API_KEY=your_mcp_api_key

# Server
PORT=3978

# Proactive Messaging (optional)
# Channel ID for alerts (get from Teams channel info)
# ALERT_CHANNEL_ID=19:abc123@thread.tacv2
# ALERT_TEAM_ID=your_team_id

# Logging
LOG_LEVEL=info
