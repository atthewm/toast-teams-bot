# Azure Entra ID App Registration (required)
ENTRA_APP_CLIENT_ID=your_app_client_id
ENTRA_APP_CLIENT_SECRET=your_app_client_secret
ENTRA_TENANT_ID=your_tenant_id

# Toast MCP Server (required)
MCP_SERVER_URL=http://localhost:3000/mcp
MCP_API_KEY=

# Server
PORT=3978

# Logging
LOG_LEVEL=info

# AI: Natural language mode (required)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o

# Scheduling
TIMEZONE=America/Chicago

# RBAC: Azure AD Group IDs (leave blank for open access)
ADMIN_GROUP_ID=
MANAGER_GROUP_ID=
