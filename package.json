{
  "name": "toast-teams-bot",
  "version": "0.2.0",
  "description": "Microsoft Teams bot for Toast restaurant operations. Connects to Toast MCP Server for AI powered restaurant queries, alerts, and dashboards.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "teams",
    "bot",
    "toast",
    "restaurant",
    "mcp",
    "adaptive-cards",
    "copilot"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atthewm/toast-teams-bot"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@microsoft/teams.ai": "^2.0.5",
    "@microsoft/teams.api": "^2.0.5",
    "@microsoft/teams.apps": "^2.0.5",
    "@microsoft/teams.cards": "^2.0.5",
    "@microsoft/teams.common": "^2.0.5",
    "@microsoft/teams.mcpclient": "^2.0.5",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
